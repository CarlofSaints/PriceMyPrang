# ---------------------------------------------------------------------------
# Price my Prang — environment variables
# Copy to .env.local for local dev; set the same in Vercel for production.
# ---------------------------------------------------------------------------

# Session signing secret (any long random string). REQUIRED.
SESSION_SECRET=

# One-time admin bootstrap secret used by POST /api/seed. REQUIRED to seed.
SEED_SECRET=

# Vercel Blob storage — auto-added when you link a Blob store in Vercel.
BLOB_READ_WRITE_TOKEN=

# Google Maps (consumer map). Public key, restricted to your domains.
# Enable: Maps JavaScript API + Geocoding API on a billing-enabled project.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Optional separate server key for geocoding (falls back to the public key).
GEOCODING_API_KEY=

# Anthropic (Claude) — reads the licence disc. Optional (flow still works without).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Resend email. Use the OuterJoin Resend key for testing.
RESEND_API_KEY=
# Verified sender. For production: "Price my Prang <prang@pricemyprang.co.za>".
# Leave blank to use the Resend sandbox sender for local testing.
EMAIL_FROM=
# Comma-separated list of assessor/admin inboxes to notify on new requests.
ADMIN_NOTIFY_EMAILS=

# Public base URL (used in emails). e.g. https://www.pricemyprang.co.za
NEXT_PUBLIC_APP_URL=
